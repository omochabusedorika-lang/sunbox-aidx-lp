            <span class="price-main">30万円</span>
            <span class="price-main">30万円〜</span>
          </div>
        </div>
        
        <div class="pricing-row">
          <div class="pricing-cell pricing-cell--label">
            <span class="pricing-step">STEP 3</span>
            <strong>月額保守</strong>
          </div>
          <div class="pricing-cell">
